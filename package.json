{
  "name": "world-anvil-exporter",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "contributors": [
    {
      "name": "Kelsey Morse-Brown",
      "url": "https://github.com/kelseymorsebrown"
    },
    {
      "name": "Joe Bir",
      "url": "https://github.com/joebir"
    },
    {
      "name": "Carly Ho",
      "url": "https://github.com/cmho"
    }
  ],
  "scripts": {
    "start": "react-router dev",
    "build": "react-router build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage .",
    "test:debug": "jest --inspect-brk --runInBand --no-cache",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "typecheck": "react-router typegen && tsc --noEmit",
    "server": "cd server && npx tsx --env-file=.env src/app.ts",
    "server:dev": "cd server && npx tsx watch --env-file=../.env --env-file=.env src/app.ts",
    "dev": "concurrently \"npm run server:dev\" \"npm start\"",
    "build:server": "cd server && tsc",
    "check:auth": "node debug-auth.js"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@react-router/node": "^7.8.1",
    "browserslist-to-esbuild": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.0",
    "express": "^5.1.0",
    "express-session": "^1.18.1",
    "isbot": "^5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router": "^7.8.1",
    "react-select": "^5.10.1",
    "web-vitals": "^4.2.4"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.0.1",
    "@eslint/js": "^9.25.0",
    "@jest/globals": "^29.7.0",
    "@react-router/dev": "^7.8.1",
    "@storybook/addon-a11y": "^9.0.16",
    "@storybook/addon-docs": "^9.0.16",
    "@storybook/addon-onboarding": "^9.0.16",
    "@storybook/addon-vitest": "^9.0.16",
    "@storybook/react-vite": "^9.0.16",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/express-session": "^1.18.2",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitejs/plugin-react-swc": "^3.9.0",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "babel-jest": "^29.7.0",
    "concurrently": "^9.2.0",
    "eslint": "^9.25.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-jest": "^28.11.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "eslint-plugin-storybook": "^9.0.16",
    "globals": "^16.0.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-fixed-jsdom": "^0.0.9",
    "jest-transformer-svg": "^2.1.0",
    "playwright": "^1.54.1",
